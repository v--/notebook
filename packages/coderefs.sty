\ExplSyntaxOn

\msg_new:nnn {notebook} {coderefs-missing} {No~code~reference~for~#1}

\prop_new:N \g_nb_coderef_prop
\tl_new:N \l_nb_coderef_content_tl

\NewDocumentCommand \ProcessCodeRefs {O{aux/coderefs.tex}}
  {
    \file_input:n {#1}
  }

\NewDocumentCommand \GetCodeRef {m}
  {
    \prop_get:NnNTF \g_nb_coderef_prop {#1} \l_nb_coderef_content_tl
      {
        \tl_use:N \l_nb_coderef_content_tl
      }
      {
        \msg_error:nnn {notebook} {coderefs-missing} {#1}
      }
  }

\NewDocumentCommand \WriteCodeRefText {sm}
  {
    \IfValueT {#1} {\\[1ex] \hbox{\quad}}
    \texttt{#2}
  }

\NewDocumentCommand \WriteCodeRef {m}
  {
    \WriteCodeRefText{\GetCodeRef{#1}}
  }

\ExplSyntaxOff
