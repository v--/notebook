\ExplSyntaxOn

\prop_new:N \g_nb_coderef_prop
\tl_new:N \l_nb_coderef_coderef_tl

\NewDocumentCommand \ProcessCodeRefs {O{aux/coderefs.tex}}
  {
    \file_input:n {#1}
  }

\NewDocumentCommand \GetCodeRef {O{}}
  {
    \prop_get:NnN \g_nb_coderef_prop {#1} \l_nb_coderef_coderef_tl
    \tl_use:N \l_nb_coderef_coderef_tl
  }

\NewDocumentCommand \WriteCodeRef {O{}}
  {
    \newline\hbox{\quad}\texttt{\GetCodeRef[#1]}
  }

\ExplSyntaxOff
